# Database Configuration
DATABASE_URL=mysql+pymysql://user:password@localhost/maintenance_db

# Security
SECRET_KEY=enter_your_super_secret_key_here
JWT_SECRET_KEY=enter_your_jwt_signing_key_here

# App Settings
FLASK_APP=backend/app.py
FLASK_ENV=production
DEBUG=False

# Email SMTP (For simulated notifications)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
